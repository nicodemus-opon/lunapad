		"prepare": "svelte-kit sync || echo ''",
		"test": "vitest run",
		"test:e2e": "playwright test --project=mocked",
		"test:e2e:mock": "playwright test --project=mocked",
		"test:e2e:llm": "playwright test --project=llm",
