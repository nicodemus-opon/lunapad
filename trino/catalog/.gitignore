# User-added data source catalog files contain connection credentials.
# Only the bundled catalogs (tpch, docker_postgres) are tracked.
*.properties
!tpch.properties
!docker_postgres.properties

# Runtime-rewritten Trino access-control rules (per-org catalog grants appended
# by connections.ts's ensureTenantTrinoAccess). Same reasoning as the *.properties
# rule above — never track it; it's seeded from baseTrinoAccessRules() if missing.
lunapad-access-control.json
